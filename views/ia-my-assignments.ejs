<%- include("partials-header", { title: "My IA Assignments" }) %>

<section class="toolbar">
  <h1>My IA Assignments</h1>
  <a href="/ia" class="btn btn-ghost">Back to IA Dossiers</a>
</section>

<section class="grid">
  <% if (!dossiers || dossiers.length === 0) { %><article class="card"><p class="muted">No IA dossiers assigned to you yet.</p></article><% } %>
  <% dossiers.forEach((dossier) => { %>
    <article class="card dossier-card">
      <div class="card-head">
        <h2><%= dossier.name %></h2>
        <span class="pill pill-<%= dossier.risk_level.toLowerCase() %>"><%= dossier.risk_level %> Risk</span>
      </div>
      <p class="muted"><%= dossier.faction %></p>
      <p><strong>Reports:</strong> <span class="report-count"><%= dossier.report_count %></span></p>
      <p><strong>Created By:</strong> <%= dossier.created_by_username || "Unknown" %></p>
      <a class="btn btn-ghost" href="/ia/<%= dossier.id %>">View IA dossier</a>
    </article>
  <% }) %>
</section>

<%- include("partials-footer") %>
